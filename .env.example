# Copy this file to .env and fill in your values before running.
# Uncomment the block that matches your setup.

# ============================================================
# DATABASE — required
# ============================================================
DATABASE_URL=sqlite:///./data/llm_eval.db

# ============================================================
# EXAMPLE 1: Cloud LLM (Gemini) + Gemini judge
# ============================================================
# Get a free Gemini key at https://aistudio.google.com/apikey
# Start with: docker compose up
#
# LLM_MODEL=gemini/gemini-2.5-flash-lite
# GEMINI_API_KEY=your-gemini-key
# LLM_JUDGE_MODELS=gemini/gemini-2.5-flash-lite

# ============================================================
# EXAMPLE 2: Local LLM (Ollama/TinyLlama) + Gemini judge
# ============================================================
# TinyLlama (~600 MB) — fast on CPU, good for testing.
# Switch LLM_MODEL to ollama/mistral (~4 GB) for better quality.
# Start with: docker compose --profile local-llm up
#
# LLM_MODEL=ollama/tinyllama
# LLM_API_BASE=http://ollama:11434
# GEMINI_API_KEY=your-gemini-key
# LLM_JUDGE_MODELS=gemini/gemini-2.5-flash-lite

# ============================================================
# EXAMPLE 3: Multiple cloud judges (reduces self-evaluation bias)
# ============================================================
# Get keys at: https://aistudio.google.com/apikey
#              https://platform.openai.com/api-keys
#              https://console.anthropic.com/settings/keys
# Start with: docker compose up
#
# LLM_MODEL=gemini/gemini-2.5-flash-lite
# GEMINI_API_KEY=your-gemini-key
# OPENAI_API_KEY=your-openai-key
# ANTHROPIC_API_KEY=your-anthropic-key
#
# Light judges — fast and cheap, good for development:
# LLM_JUDGE_MODELS=gemini/gemini-2.5-flash-lite,openai/gpt-4o-mini,anthropic/claude-haiku-4-5-20251001
#
# Strong judges — more reliable, higher cost, recommended for production:
# Verify the latest model IDs at:
#   https://docs.litellm.ai/docs/providers/gemini
#   https://docs.litellm.ai/docs/providers/openai
#   https://docs.litellm.ai/docs/providers/anthropic
# LLM_JUDGE_MODELS=gemini/gemini-2.5-pro,openai/gpt-4o,anthropic/claude-sonnet-4-6

# ============================================================
# EXAMPLE 4: Mock (no LLM — for development without API keys)
# ============================================================
# If LLM_MODEL is not set, a mock response is returned automatically.
# Start with: docker compose up
